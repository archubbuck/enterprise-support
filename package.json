{
    "name": "enterprise-support",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:kill": "fuser -k 5000/tcp",
        "build": "tsc -b && vite build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "build:optimize": "vite optimize",
        "preview": "vite preview",
        "validate:json": "node scripts/validate-json.cjs",
        "validate:app-config": "node scripts/validate-app-config.cjs",
        "validate:metadata": "node scripts/prepare-fastlane-metadata.cjs --validate-only",
        "prepare:metadata": "node scripts/prepare-fastlane-metadata.cjs",
        "validate:all": "npm run validate:json && npm run validate:app-config && npm run validate:metadata && npm run lint",
        "ios:build": "npm run build && npx cap sync ios",
        "ios:open": "npx cap open ios",
        "ios:run": "npm run ios:build && npm run ios:open",
        "ios:enterprise:setup": "cd ios/App && bundle exec fastlane setup_enterprise_certificates",
        "ios:enterprise:build": "npm run build && npx cap sync ios && cd ios/App && bundle exec fastlane build_enterprise",
        "cap:sync": "npx cap sync",
        "cap:copy": "npx cap copy",
        "prepare": "husky"
    },
    "dependencies": {
        "@capacitor/core": "^8.0.2",
        "@capacitor/ios": "^8.0.2",
        "@github/spark": ">=0.43.1 <1",
        "@heroicons/react": "^2.2.0",
        "@hookform/resolvers": "^5.2.2",
        "@octokit/core": "^7.0.6",
        "@phosphor-icons/react": "^2.1.7",
        "@radix-ui/react-accordion": "^1.2.3",
        "@radix-ui/react-alert-dialog": "^1.1.6",
        "@radix-ui/react-aspect-ratio": "^1.1.2",
        "@radix-ui/react-avatar": "^1.1.3",
        "@radix-ui/react-checkbox": "^1.1.4",
        "@radix-ui/react-collapsible": "^1.1.3",
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.6",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-menubar": "^1.1.6",
        "@radix-ui/react-navigation-menu": "^1.2.5",
        "@radix-ui/react-popover": "^1.1.6",
        "@radix-ui/react-progress": "^1.1.2",
        "@radix-ui/react-radio-group": "^1.2.3",
        "@radix-ui/react-scroll-area": "^1.2.9",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.2",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.2",
        "@radix-ui/react-switch": "^1.1.3",
        "@radix-ui/react-tabs": "^1.1.3",
        "@radix-ui/react-toggle": "^1.1.2",
        "@radix-ui/react-toggle-group": "^1.1.2",
        "@radix-ui/react-tooltip": "^1.1.8",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-query": "^5.90.20",
        "@use-gesture/react": "^10.3.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "d3": "^7.9.0",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "dompurify": "^3.3.1",
        "embla-carousel-react": "^8.5.2",
        "framer-motion": "^12.23.26",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.562.0",
        "mammoth": "^1.11.0",
        "marked": "^17.0.1",
        "octokit": "^5.0.5",
        "react": "^19.2.3",
        "react-day-picker": "^9.13.0",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.0",
        "react-hook-form": "^7.71.1",
        "react-is": "^19.2.4",
        "react-pdf": "^10.3.0",
        "react-resizable-panels": "^4.5.3",
        "recharts": "^3.7.0",
        "sonner": "^2.0.1",
        "tailwind-merge": "^3.0.2",
        "three": "^0.182.0",
        "tw-animate-css": "^1.2.4",
        "uuid": "^13.0.0",
        "vaul": "^1.1.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.0.2",
        "@eslint/js": "^9.39.2",
        "@tailwindcss/postcss": "^4.1.18",
        "@types/dompurify": "^3.0.5",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.2.2",
        "eslint": "^9.39.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^17.0.0",
        "tailwindcss": "^4.1.18",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.51.0",
        "vite": "^7.3.0",
        "vitest": "^3.2.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/user-event": "^14.6.1",
        "jsdom": "^26.1.0",
        "eslint-plugin-import": "^2.31.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.0"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix"
        ],
        "*.json": [
            "node scripts/validate-json.cjs"
        ]
    },
    "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.0.0"
    }
}
