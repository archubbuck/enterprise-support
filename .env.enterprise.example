# Enterprise (In-House) Distribution — Environment Variables
#
# Copy this file to .env.enterprise.local and fill in the values.
# These are required for building an enterprise IPA for MDM distribution.
#
# See docs/topics/ios-development.md for setup instructions.

# Apple Developer Enterprise Program Team ID (10-character string).
# If your Enterprise account uses a different team than App Store, set this.
# Falls back to APPLE_TEAM_ID if not set.
APPLE_TEAM_ID=<REPLACE>

# App Store Connect API key for the Enterprise team
APPSTORE_KEY_ID=<REPLACE>
APPSTORE_ISSUER_ID=<REPLACE>
APPSTORE_P8=<REPLACE>

# Match — certificate/profile management
MATCH_PASSWORD=<REPLACE>
MATCH_GIT_URL=<REPLACE>
GIT_AUTHORIZATION=<REPLACE>

# Bundle identifier (optional, defaults to com.enterprise.support)
# APP_IDENTIFIER=com.enterprise.support
